---
import { getCollection } from "astro:content";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import ProjectCard from "../components/ProjectCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  SITE,
  book,
  education,
  experience,
  expertise,
  heroStats,
  organizations,
  withBase,
  testimonials
} from "../lib/site";

const featuredProjects = (await getCollection("projects"))
  .filter((entry) => entry.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: SITE.name,
  jobTitle: "R&D Talent Strategy & Talent Acquisition Leader",
  description: SITE.description,
  worksFor: {
    "@type": "Organization",
    name: "Atlan",
    url: SITE.company
  },
  url: withBase("/"),
  image: new URL("/assets/headshot.jpg", SITE.site).toString(),
  sameAs: [SITE.linkedin, SITE.github],
  alumniOf: {
    "@type": "EducationalOrganization",
    name: "IIM Nagpur"
  },
  knowsAbout: [
    "Talent Acquisition",
    "AI systems",
    "Prompt governance",
    "Evaluation frameworks",
    "Hiring systems"
  ]
};
---
<BaseLayout
  title="Rishi Banerjee - Business Leader, Builder, Talent Strategist"
  description={SITE.description}
  jsonLd={jsonLd}
>
  <Nav />

  <main id="main-content">
    <section class="hero-section">
      <div class="container hero-grid">
        <div class="hero-copy" data-reveal>
          <p class="eyebrow">Business Leader. Builder. Talent Strategist.</p>
          <h1>{SITE.name}</h1>
          <p class="hero-text">
            I lead R&amp;D hiring at <a href={SITE.company} target="_blank" rel="noopener">Atlan</a> — Engineering, Product, Design, IT, Security.
            But I don't just run recruiting. I build the systems underneath it: interview evaluators, prompt governance frameworks, candidate research agents, offer page generators, an npm package, a macOS menubar app, and a book on hiring in the age of AI.
          </p>
          <p class="hero-text hero-text-muted">
            Most talent leaders optimize funnels. I build the infrastructure underneath them. When a judgment call happens 200 times with no system backing it up, I turn it into software.
          </p>
          <div class="button-row">
            <a href={SITE.linkedin} class="button button-primary" target="_blank" rel="noopener">LinkedIn</a>
            <a href={SITE.promptControlPlane} class="button button-secondary" target="_blank" rel="noopener">Prompt Control Plane</a>
            <a href={SITE.github} class="button button-secondary" target="_blank" rel="noopener">GitHub</a>
          </div>
          <div class="stats-grid">
            {heroStats.map((stat) => (
              <div class="stat-card">
                <strong>{stat.value}</strong>
                <span>{stat.label}</span>
              </div>
            ))}
          </div>
        </div>

        <div class="hero-aside" data-reveal>
          <img src={withBase("/assets/headshot.jpg")} alt="Rishi Banerjee" class="hero-photo" />
        </div>
      </div>
    </section>

    <section class="logo-section" data-reveal>
      <div class="container">
        <p class="eyebrow">Career Highlights</p>
        <div class="logo-row">
          {organizations.map((org) => (
            <a href={org.href} class="logo-link">
              <img
                src={withBase(org.logo)}
                alt={org.name}
                class:list={["logo-image", org.invertInDark && "logo-image-invert"]}
              />
            </a>
          ))}
        </div>
      </div>
    </section>

    <section id="about" class="section section-alt" data-reveal>
      <div class="container prose-block">
        <p class="eyebrow">About</p>
        <h2>The short version</h2>
        <p>
          20 years of building and scaling talent functions across APAC, North America, and Europe. Currently leading R&amp;D hiring at Atlan across five functions — Engineering, Product, Design, IT, and Security.
        </p>
        <p>
          The building started because I kept watching the same problems repeat: inconsistent interview feedback, offer pages that looked like they were made in 2011, candidate research that took hours and lived in someone's head. So I started writing code. Not scripts — real products, with UIs, APIs, and users.
        </p>
        <p>
          Now it's the thing I'm most known for internally. The team runs on systems I built. Externally, some of those tools are open source — an npm package with 700+ installs, a macOS app, a GitHub Action used in CI pipelines, and a prompt governance framework that other teams have adopted.
        </p>
      </div>
    </section>

    <section id="experience" class="section" data-reveal>
      <div class="container">
        <p class="eyebrow">Experience</p>
        <h2>Career</h2>
        <div class="timeline">
          {experience.map((item) => (
            <article class="timeline-item" id={item.id}>
              <div class="timeline-date">{item.date}</div>
              <div class="timeline-body">
                <h3>{item.title}</h3>
                <p class="timeline-company">
                  {item.companyHref ? (
                    <a href={item.companyHref} target="_blank" rel="noopener">{item.company}</a>
                  ) : (
                    item.company
                  )}
                  {item.subtitle && ` - ${item.subtitle}`}
                </p>
                <ul>
                  {item.bullets.map((bullet) => <li>{bullet}</li>)}
                </ul>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="expertise" class="section section-alt" data-reveal>
      <div class="container">
        <p class="eyebrow">Expertise</p>
        <h2>How I operate</h2>
        <div class="three-up-grid">
          {expertise.map((item) => (
            <article class="panel-card">
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section" data-reveal>
      <div class="container">
        <div class="section-intro">
          <div>
            <p class="eyebrow">Book</p>
            <h2>{book.title}</h2>
          </div>
        </div>
        <div class="book-card">
          <div class="book-content">
            <h3>{book.subtitle}</h3>
            <p>{book.description}</p>
            <a href={book.href} class="button button-primary" target="_blank" rel="noopener">Read on Amazon</a>
          </div>
        </div>
      </div>
    </section>

    <section class="section section-alt" data-reveal>
      <div class="container">
        <p class="eyebrow">Testimonials</p>
        <h2>What colleagues say</h2>
        <div class="three-up-grid">
          {testimonials.map((item) => (
            <blockquote class="panel-card quote-card">
              <p>"{item.quote}"</p>
              <footer>
                <strong>{item.author}</strong>
                <span>{item.context}</span>
              </footer>
            </blockquote>
          ))}
        </div>
      </div>
    </section>

    <section id="education" class="section section-alt" data-reveal>
      <div class="container">
        <p class="eyebrow">Education & Certifications</p>
        <h2>Credentials</h2>
        <div class="two-up-grid">
          {education.map((item) => (
            <article class="panel-card">
              <h3>{item.title}</h3>
              <p class="subtle-label">{item.institution}</p>
              {item.text && <p>{item.text}</p>}
              {item.tags && (
                <div class="tag-list">
                  {item.tags.map((tag) => <span class="tag">{tag}</span>)}
                </div>
              )}
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="projects" class="section" data-reveal>
      <div class="container">
        <div class="section-intro">
          <div>
            <p class="eyebrow">Flagship Projects</p>
            <h2>Products I've built</h2>
          </div>
          <a href={withBase("/projects/")} class="text-link">View all projects</a>
        </div>
        <div class="project-grid">
          {featuredProjects.map((project) => (
            <ProjectCard
              project={{
                title: project.data.title,
                shortSummary: project.data.shortSummary,
                summary: project.data.summary,
                tags: project.data.tags,
                visibility: project.data.visibility,
                status: project.data.status
              }}
              href={withBase(`/projects/${project.slug}/`)}
            />
          ))}
        </div>
      </div>
    </section>

    <section class="section cta-section" data-reveal>
      <div class="container cta-card">
        <p class="eyebrow">Get In Touch</p>
        <h2>Let’s talk</h2>
        <p>
          Whether it’s hiring systems, AI tooling for talent teams, org design, or just comparing notes on scaling recruiting without losing your mind — I’m easy to reach.
        </p>
        <div class="button-row">
          <a href={`mailto:${SITE.email}`} class="button button-primary">Email me</a>
          <a href={SITE.linkedin} class="button button-secondary" target="_blank" rel="noopener">Connect on LinkedIn</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
